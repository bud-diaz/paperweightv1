# Paperweight Configuration
# Copy this file to .env and fill in your values

# Station Identity
STATION_NAME=My Station
# 'creator' or 'anonymous'
STATION_IDENTITY=creator
CREATOR_NAME=
CREATOR_DESC=

# Server
PORT=3000

# Vault
VAULT_PATH=./vault
# 'folder', 'metadata', or 'hybrid'
VAULT_MODE=hybrid

# Dashboard access token (generated by setup.sh)
DASHBOARD_TOKEN=

# Station slug — used in your public URL: https://<slug>.paperweighthq.com
# Auto-generated from your station name during setup
STATION_SLUG=
# Your full public station URL (set automatically during setup)
STATION_PUBLIC_URL=

# Cloudflare Tunnel (optional — hides your IP address from listeners)
# Set up a tunnel at: https://one.dash.cloudflare.com → Networks → Tunnels
# Leave blank to run on your local network only
CLOUDFLARE_TUNNEL_TOKEN=

# Paths (defaults work for most installs)
DATA_PATH=./data
HLS_OUTPUT_PATH=./hls_output
LOG_PATH=./logs

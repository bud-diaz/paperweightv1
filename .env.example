# Paperweight Configuration
# Copy this file to .env and fill in your values

# Station Identity
STATION_NAME=My Station
# 'creator' or 'anonymous'
STATION_IDENTITY=creator
CREATOR_NAME=
CREATOR_DESC=

# Server
PORT=3000

# Vault
VAULT_PATH=./vault
# 'folder', 'metadata', or 'hybrid'
VAULT_MODE=hybrid

# Dashboard access token (generated by setup.sh)
DASHBOARD_TOKEN=

# Separate HMAC secret for signed download URLs.
# If unset, a random secret is generated at startup (signed URLs won't survive restarts).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOWNLOAD_SIGNING_SECRET=

# Set to 'true' when the server is behind nginx/Caddy with TLS.
# Enables the Secure flag on session cookies.
HTTPS=false

# Station slug — used in your public URL: https://<slug>.paperweighthq.com
# Auto-generated from your station name during setup
STATION_SLUG=
# Your full public station URL (set automatically during setup)
STATION_PUBLIC_URL=

# Cloudflare Tunnel (optional — hides your IP address from listeners)
# Set up a tunnel at: https://one.dash.cloudflare.com → Networks → Tunnels
# Leave blank to run on your local network only
CLOUDFLARE_TUNNEL_TOKEN=

# ─── v1.5: Monetization ──────────────────────────────────────────────────────

# Stripe (https://dashboard.stripe.com)
# Get API keys from: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
# Get webhook secret from: Stripe Dashboard → Developers → Webhooks → Add endpoint
STRIPE_WEBHOOK_SECRET=
# Create recurring prices at: Stripe Dashboard → Products → Add product
STRIPE_PRICE_SUBSCRIBER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ALL_ACCESS=

# PayPal (https://developer.paypal.com)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLAN_PRO=
PAYPAL_PLAN_ALL_ACCESS=
PAYPAL_WEBHOOK_ID=

# Download token TTL in hours (default: 48)
DOWNLOAD_TOKEN_TTL_HOURS=48

# ─── Paperweight Cloud (roadmap — keep false for self-hosted) ─────────────────
# Enables the next-phase native-app checkout deep links and the multi-station
# directory routes. These are inert and hidden (404) while false. Leave false
# unless you are running the Cloud build. See ROADMAP.md.
PAPERWEIGHT_CLOUD=false

# ─── Paths (defaults work for most installs) ─────────────────────────────────
DATA_PATH=./data
HLS_OUTPUT_PATH=./hls_output
LOG_PATH=./logs

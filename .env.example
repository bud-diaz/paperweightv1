# Paperweight configuration
# Copy this file to .env and fill in your values.

# Station identity
STATION_NAME=My Station
STATION_IDENTITY=creator
CREATOR_NAME=
CREATOR_DESC=

# Server
HOST=127.0.0.1
PORT=3000
# Use loopback for a local reverse proxy or Cloudflare tunnel; false for direct local use.
TRUST_PROXY=false

# Vault
VAULT_PATH=./vault
VAULT_MODE=hybrid

# Dashboard owner token. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_TOKEN=

# Required for public stations if downloads are enabled.
DOWNLOAD_SIGNING_SECRET=

# Set to true when public traffic reaches Paperweight through HTTPS.
HTTPS=false
STATION_SLUG=
STATION_PUBLIC_URL=

# Optional Cloudflare Tunnel token.
CLOUDFLARE_TUNNEL_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SUBSCRIBER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ALL_ACCESS=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLAN_PRO=
PAYPAL_PLAN_ALL_ACCESS=
PAYPAL_WEBHOOK_ID=

# Paperweight Cloud roadmap features remain disabled for self-hosted installs.
PAPERWEIGHT_CLOUD=false

# Paths
DATA_PATH=./data
HLS_OUTPUT_PATH=./hls_output
LOG_PATH=./logs
DOWNLOAD_TOKEN_TTL_HOURS=48

# ── system.pape Telemetry (optional) ─────────────────────────────────────────
# Enable to report station metrics to your Paperweight System instance.
# All three must be set; leave blank to disable.
PAPE_URL=
PAPE_TELEMETRY_SECRET=
# A stable, unique name for this station (e.g. "rollingwoods-primary").
# Can be any string — it identifies this installation in system.pape.
STATION_KEY=
# How often to report, in milliseconds. Default: 300000 (5 minutes).
PAPE_REPORT_INTERVAL_MS=300000

{
  "name": "paperweight-desktop",
  "version": "1.5.1",
  "private": true,
  "description": "Paperweight desktop app (Windows & Mac)",
  "main": "main.js",
  "scripts": {
    "start": "electron main.js",
    "electron:rebuild": "node scripts/rebuild-native.js",
    "dist": "npm run electron:rebuild && electron-builder --mac --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "@electron/rebuild": "^3.6.0"
  },
  "build": {
    "appId": "com.paperweight.desktop",
    "productName": "Paperweight",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!native/**"
    ],
    "extraResources": [
      { "from": "../src", "to": "src" },
      { "from": "../client", "to": "client" },
      { "from": "../node_modules", "to": "node_modules", "filter": ["!better-sqlite3/**"] },
      { "from": "../package.json", "to": "package.json" },
      { "from": "native/node_modules/better-sqlite3", "to": "node_modules/better-sqlite3" }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns",
      "category": "public.app-category.music"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    }
  }
}

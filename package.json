{
  "name": "paperweight",
  "version": "1.0.0",
  "description": "Anchor your creative archive.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build:exe": "node scripts/build-exe.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^3.6.0",
    "cookie-parser": "^1.4.6",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.12.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js",
      "scripts/preflight.js"
    ],
    "assets": [
      "client/**/*",
      "node_modules/better-sqlite3/build/Release/*.node",
      "node_modules/better-sqlite3/build/Release/*.dll"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  }
}
